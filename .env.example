# ── Database (PostgreSQL 16 + pgvector) ──
POSTGRES_USER=campusmind
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=campusmind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://campusmind:change-me-in-production@postgres:5432/campusmind

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── JWT Auth ──
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── DeepSeek AI (primary LLM) ──
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Optional: OpenAI Compatible Providers ──
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── App ──
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ── Upload Limits ──
MAX_UPLOAD_SIZE_MB=20
