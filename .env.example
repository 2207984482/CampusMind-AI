# Database
POSTGRES_USER=campusmind
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=campusmind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://campusmind:change-me-in-production@postgres:5432/campusmind

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
